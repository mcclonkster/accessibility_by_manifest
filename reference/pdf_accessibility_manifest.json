{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pdf_accessibility_manifest.v0.1.schema.json",
  "title": "pdf_accessibility_manifest v0.1",
  "description": "Accessibility-first PDF evidence manifest. This schema records source evidence, normalization decisions, review flags, and projected DOCX output.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "manifest_kind",
    "extractor_provenance",
    "extractor_evidence",
    "source_package",
    "target_package",
    "run_config",
    "document_summary",
    "document_metadata",
    "document_accessibility",
    "document_navigation",
    "document_security",
    "document_interactivity",
    "document_warning_entries",
    "page_entries",
    "raw_block_entries",
    "normalized_block_entries",
    "projected_target"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "0.1"
    },
    "manifest_kind": {
      "type": "string",
      "const": "pdf_accessibility_manifest"
    },
    "extractor_provenance": {
      "type": "object",
      "additionalProperties": true
    },
    "extractor_evidence": {
      "type": "object",
      "additionalProperties": true
    },
    "source_package": {
      "$ref": "#/$defs/source_package"
    },
    "target_package": {
      "$ref": "#/$defs/target_package"
    },
    "run_config": {
      "$ref": "#/$defs/run_config"
    },
    "document_summary": {
      "$ref": "#/$defs/document_summary"
    },
    "document_metadata": {
      "$ref": "#/$defs/document_metadata"
    },
    "document_accessibility": {
      "$ref": "#/$defs/document_accessibility"
    },
    "document_navigation": {
      "$ref": "#/$defs/document_navigation"
    },
    "document_security": {
      "$ref": "#/$defs/document_security"
    },
    "document_interactivity": {
      "$ref": "#/$defs/document_interactivity"
    },
    "document_warning_entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning_entry"
      }
    },
    "page_entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/page_entry"
      }
    },
    "raw_block_entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/raw_block_entry"
      }
    },
    "normalized_block_entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/normalized_block_entry"
      }
    },
    "projected_target": {
      "$ref": "#/$defs/projected_target"
    }
  },
  "$defs": {
    "nullable_string": {
      "type": [
        "string",
        "null"
      ]
    },
    "nullable_boolean": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "nullable_integer": {
      "type": [
        "integer",
        "null"
      ]
    },
    "nullable_number": {
      "type": [
        "number",
        "null"
      ]
    },
    "bbox": {
      "type": [
        "array",
        "null"
      ],
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "number"
      }
    },
    "warning_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "warning_code",
        "warning_message",
        "warning_scope",
        "manual_review_required"
      ],
      "properties": {
        "warning_code": {
          "type": "string"
        },
        "warning_message": {
          "type": "string"
        },
        "warning_scope": {
          "type": "string",
          "enum": [
            "document",
            "page",
            "block",
            "annotation",
            "figure",
            "form",
            "navigation",
            "security",
            "metadata",
            "ocr",
            "reading_order"
          ]
        },
        "warning_severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "error"
          ],
          "default": "warning"
        },
        "manual_review_required": {
          "type": "boolean"
        }
      }
    },
    "source_package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format_family",
        "input_file_name",
        "input_file_path",
        "page_count",
        "document_fingerprints"
      ],
      "properties": {
        "format_family": {
          "type": "string",
          "const": "PDF"
        },
        "input_file_name": {
          "type": "string"
        },
        "input_file_path": {
          "type": "string"
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        },
        "document_fingerprints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "maxItems": 2
        },
        "byte_length": {
          "$ref": "#/$defs/nullable_integer"
        }
      }
    },
    "target_package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "format_family",
        "package_model",
        "document_vocabulary",
        "draft_output_file_name",
        "draft_output_file_path"
      ],
      "properties": {
        "format_family": {
          "type": "string",
          "const": "OOXML"
        },
        "package_model": {
          "type": "string",
          "const": "OPC"
        },
        "document_vocabulary": {
          "type": "string",
          "const": "WordprocessingML"
        },
        "draft_output_file_name": {
          "type": "string"
        },
        "draft_output_file_path": {
          "type": "string"
        }
      }
    },
    "run_config": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "include_preview_images",
        "preview_image_dir",
        "page_separator_mode",
        "include_warning_appendix",
        "include_page_traceback",
        "prefer_outline_for_headings"
      ],
      "properties": {
        "include_preview_images": {
          "type": "boolean"
        },
        "preview_image_dir": {
          "$ref": "#/$defs/nullable_string"
        },
        "page_separator_mode": {
          "type": "string",
          "enum": [
            "PAGE_BREAK",
            "SECTION_BREAK",
            "NONE"
          ]
        },
        "include_warning_appendix": {
          "type": "boolean"
        },
        "include_page_traceback": {
          "type": "boolean"
        },
        "prefer_outline_for_headings": {
          "type": "boolean"
        }
      }
    },
    "document_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "total_pages",
        "pages_with_warnings",
        "raw_block_count",
        "normalized_block_count",
        "annotation_count",
        "form_field_count",
        "figure_candidate_count"
      ],
      "properties": {
        "total_pages": {
          "type": "integer",
          "minimum": 1
        },
        "pages_with_warnings": {
          "type": "integer",
          "minimum": 0
        },
        "raw_block_count": {
          "type": "integer",
          "minimum": 0
        },
        "normalized_block_count": {
          "type": "integer",
          "minimum": 0
        },
        "annotation_count": {
          "type": "integer",
          "minimum": 0
        },
        "form_field_count": {
          "type": "integer",
          "minimum": 0
        },
        "figure_candidate_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "document_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "info",
        "xmp_present",
        "title",
        "author",
        "subject",
        "keywords",
        "language"
      ],
      "properties": {
        "info": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "xmp_present": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "title": {
          "$ref": "#/$defs/nullable_string"
        },
        "author": {
          "$ref": "#/$defs/nullable_string"
        },
        "subject": {
          "$ref": "#/$defs/nullable_string"
        },
        "keywords": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "language": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "document_accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mark_info",
        "tagged_pdf_detected",
        "struct_tree_detected",
        "image_only_pages_present",
        "ocr_required",
        "ocr_detected",
        "reading_order_source"
      ],
      "properties": {
        "mark_info": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "tagged_pdf_detected": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "struct_tree_detected": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "image_only_pages_present": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "ocr_required": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "ocr_detected": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "reading_order_source": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "tag_tree",
            "layout_inference",
            "mixed",
            "unknown",
            null
          ]
        }
      }
    },
    "document_navigation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outline_present",
        "outline_entries",
        "page_labels",
        "named_destinations_present",
        "named_destinations",
        "viewer_preferences",
        "page_layout",
        "page_mode"
      ],
      "properties": {
        "outline_present": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "outline_entries": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/$defs/outline_entry"
          }
        },
        "page_labels": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "named_destinations_present": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "named_destinations": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "viewer_preferences": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "page_layout": {
          "$ref": "#/$defs/nullable_string"
        },
        "page_mode": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "document_security": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "permissions"
      ],
      "properties": {
        "permissions": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": [
              "integer",
              "string"
            ]
          }
        }
      }
    },
    "document_interactivity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "javascript_present",
        "javascript_actions",
        "forms_present",
        "form_fields",
        "calculation_order_ids",
        "xfa_present",
        "is_pure_xfa",
        "all_xfa_html"
      ],
      "properties": {
        "javascript_present": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "javascript_actions": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "forms_present": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "form_fields": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "calculation_order_ids": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "xfa_present": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "is_pure_xfa": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "all_xfa_html": {
          "type": [
            "object",
            "array",
            "null"
          ]
        }
      }
    },
    "outline_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "dest": {
          "type": [
            "string",
            "array",
            "null"
          ]
        },
        "url": {
          "$ref": "#/$defs/nullable_string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/outline_entry"
          }
        }
      }
    },
    "page_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_number",
        "observed_source",
        "struct_tree",
        "annotation_entries",
        "xfa_entries",
        "operator_evidence",
        "extractor_evidence",
        "warning_entries"
      ],
      "properties": {
        "page_number": {
          "type": "integer",
          "minimum": 1
        },
        "observed_source": {
          "$ref": "#/$defs/page_observed_source"
        },
        "struct_tree": {
          "type": [
            "object",
            "array",
            "null"
          ]
        },
        "annotation_entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/annotation_entry"
          }
        },
        "xfa_entries": {
          "type": [
            "object",
            "array",
            "null"
          ]
        },
        "operator_evidence": {
          "type": [
            "object",
            "array",
            "null"
          ]
        },
        "extractor_evidence": {
          "type": "object",
          "additionalProperties": true
        },
        "warning_entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning_entry"
          }
        }
      }
    },
    "page_observed_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "page_ref",
        "page_rotation",
        "user_unit",
        "page_bbox",
        "viewport",
        "struct_tree_present",
        "text_layer_detected",
        "image_only_page_suspected",
        "ocr_text_detected",
        "annotation_count",
        "form_field_count",
        "xfa_present",
        "operator_list_present",
        "page_label"
      ],
      "properties": {
        "page_ref": {
          "$ref": "#/$defs/nullable_string"
        },
        "page_rotation": {
          "$ref": "#/$defs/nullable_number"
        },
        "user_unit": {
          "$ref": "#/$defs/nullable_number"
        },
        "page_bbox": {
          "$ref": "#/$defs/bbox"
        },
        "viewport": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "struct_tree_present": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "text_layer_detected": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "image_only_page_suspected": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "ocr_text_detected": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "annotation_count": {
          "type": "integer",
          "minimum": 0
        },
        "form_field_count": {
          "type": "integer",
          "minimum": 0
        },
        "xfa_present": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "operator_list_present": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "page_label": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "annotation_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "annotation_subtype",
        "contents",
        "alt_text",
        "url",
        "dest",
        "manual_review_required"
      ],
      "properties": {
        "annotation_subtype": {
          "$ref": "#/$defs/nullable_string"
        },
        "contents": {
          "$ref": "#/$defs/nullable_string"
        },
        "alt_text": {
          "$ref": "#/$defs/nullable_string"
        },
        "url": {
          "$ref": "#/$defs/nullable_string"
        },
        "dest": {
          "type": [
            "string",
            "array",
            "null"
          ]
        },
        "manual_review_required": {
          "type": "boolean"
        }
      }
    },
    "raw_block_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "block_id",
        "page_number",
        "source_evidence_type",
        "source_ref",
        "bbox",
        "text",
        "text_items",
        "style_hints",
        "structure_hints",
        "role_basis",
        "manual_review_required",
        "warning_entries"
      ],
      "properties": {
        "block_id": {
          "type": "string"
        },
        "page_number": {
          "type": "integer",
          "minimum": 1
        },
        "source_evidence_type": {
          "type": "string",
          "enum": [
            "tagged_text",
            "untagged_text",
            "ocr_text",
            "annotation_text",
            "form_field_text",
            "xfa_text",
            "outline_text",
            "artifact_text",
            "unknown"
          ]
        },
        "source_ref": {
          "$ref": "#/$defs/nullable_string"
        },
        "bbox": {
          "$ref": "#/$defs/bbox"
        },
        "text": {
          "type": "string"
        },
        "text_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/text_item"
          }
        },
        "style_hints": {
          "$ref": "#/$defs/style_hints"
        },
        "structure_hints": {
          "$ref": "#/$defs/structure_hints"
        },
        "role_basis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manual_review_required": {
          "type": "boolean"
        },
        "warning_entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning_entry"
          }
        },
        "extractor_evidence": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "text_item": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "str": {
          "type": "string"
        },
        "dir": {
          "$ref": "#/$defs/nullable_string"
        },
        "width": {
          "$ref": "#/$defs/nullable_number"
        },
        "height": {
          "$ref": "#/$defs/nullable_number"
        },
        "fontName": {
          "$ref": "#/$defs/nullable_string"
        },
        "transform": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "number"
          }
        }
      }
    },
    "style_hints": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "font_name",
        "font_size",
        "font_weight",
        "font_style"
      ],
      "properties": {
        "font_name": {
          "$ref": "#/$defs/nullable_string"
        },
        "font_size": {
          "$ref": "#/$defs/nullable_number"
        },
        "font_weight": {
          "$ref": "#/$defs/nullable_string"
        },
        "font_style": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "structure_hints": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "tag_name",
        "parent_tag_name",
        "mcid",
        "language"
      ],
      "properties": {
        "tag_name": {
          "$ref": "#/$defs/nullable_string"
        },
        "parent_tag_name": {
          "$ref": "#/$defs/nullable_string"
        },
        "mcid": {
          "$ref": "#/$defs/nullable_integer"
        },
        "language": {
          "$ref": "#/$defs/nullable_string"
        }
      }
    },
    "normalized_block_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "block_id",
        "page_span",
        "observed_source_refs",
        "normalized_workflow",
        "warning_entries",
        "projected_target"
      ],
      "properties": {
        "block_id": {
          "type": "string"
        },
        "page_span": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "integer",
            "minimum": 1
          }
        },
        "observed_source_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "normalized_workflow": {
          "$ref": "#/$defs/normalized_workflow"
        },
        "warning_entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning_entry"
          }
        },
        "projected_target": {
          "$ref": "#/$defs/block_projected_target"
        }
      }
    },
    "normalized_workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interpreted_role",
        "heading_level",
        "list_kind",
        "role_confidence",
        "semantic_source_quality",
        "role_basis",
        "reading_order_index",
        "reading_order_basis",
        "manual_review_required"
      ],
      "properties": {
        "interpreted_role": {
          "type": "string",
          "enum": [
            "heading",
            "paragraph",
            "list",
            "list_item",
            "table",
            "table_row",
            "table_cell",
            "figure",
            "caption",
            "link",
            "form_field",
            "note",
            "artifact",
            "unknown"
          ]
        },
        "heading_level": {
          "$ref": "#/$defs/nullable_integer"
        },
        "list_kind": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "plain",
            "bullet",
            "number",
            "unknown",
            null
          ]
        },
        "role_confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "semantic_source_quality": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "role_basis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reading_order_index": {
